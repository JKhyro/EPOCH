<Window
    x:Class="Epoch.App.MainWindow"
    xmlns="https://github.com/avaloniaui"
    xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
    Title="EPOCH App"
    Width="1120"
    Height="720"
    MinWidth="860"
    MinHeight="560"
    Background="#f7f8fb">
  <Grid RowDefinitions="Auto,*,Auto" Margin="28">
    <Grid ColumnDefinitions="*,Auto" Margin="0,0,0,22">
      <StackPanel Spacing="6">
        <TextBlock Text="EPOCH App" FontSize="30" FontWeight="SemiBold" Foreground="#172033" />
        <TextBlock Text="{Binding CustomerSafeStatus}" FontSize="14" Foreground="#4a5568" TextWrapping="Wrap" MaxWidth="760" />
      </StackPanel>
      <Border Grid.Column="1" Padding="14,8" CornerRadius="8" Background="#e8f7ef" BorderBrush="#98d8b7" BorderThickness="1">
        <TextBlock Text="{Binding CoreStatus}" FontWeight="SemiBold" Foreground="#0f6844" />
      </Border>
    </Grid>

    <ScrollViewer Grid.Row="1" VerticalScrollBarVisibility="Auto">
      <StackPanel Spacing="18">
        <Border Padding="20" CornerRadius="8" Background="White" BorderBrush="#b9d4ea" BorderThickness="1">
          <StackPanel Spacing="12">
            <Grid ColumnDefinitions="*,Auto" ColumnSpacing="16">
              <StackPanel Spacing="6">
                <TextBlock Text="Schedule Operations Board" FontSize="22" FontWeight="SemiBold" Foreground="#172033" />
                <TextBlock Text="{Binding OperationsBoardStatus}" FontSize="18" FontWeight="SemiBold" Foreground="#294a80" />
              </StackPanel>
              <Border Grid.Column="1" Padding="12,7" CornerRadius="8" Background="#f2f6fb" BorderBrush="#c8d7ea" BorderThickness="1">
                <TextBlock Text="{Binding OperationsBoardReadyForOperatorReview}" FontWeight="SemiBold" Foreground="#294a80" />
              </Border>
            </Grid>
            <TextBlock Text="{Binding OperationsBoardNextAction}" TextWrapping="Wrap" Foreground="#526071" />
            <Border Padding="14" CornerRadius="8" Background="#f7fbff" BorderBrush="#d6e4f3" BorderThickness="1">
              <StackPanel Spacing="6">
                <TextBlock Text="Customer-Safe Status Feedback" FontWeight="SemiBold" Foreground="#172033" />
                <TextBlock Text="{Binding CustomerStatusFeedbackSummary}" TextWrapping="Wrap" Foreground="#526071" />
                <TextBlock Text="{Binding CustomerStatusFeedbackStatus}" TextWrapping="Wrap" Foreground="#526071" />
                <TextBlock Text="{Binding CustomerStatusFeedbackMessage}" TextWrapping="Wrap" Foreground="#526071" />
              </StackPanel>
            </Border>
            <Border Padding="14" CornerRadius="8" Background="#fffaf2" BorderBrush="#ead8b4" BorderThickness="1">
              <StackPanel Spacing="6">
                <TextBlock Text="Schedule Lifecycle Actions" FontWeight="SemiBold" Foreground="#172033" />
                <TextBlock Text="{Binding ScheduleLifecycleActionSummary}" TextWrapping="Wrap" Foreground="#526071" />
                <TextBlock Text="{Binding ScheduleLifecycleActionStatus}" TextWrapping="Wrap" Foreground="#526071" />
                <TextBlock Text="{Binding ScheduleLifecycleActionLocation}" TextWrapping="Wrap" FontSize="11" Foreground="#687588" />
                <TextBlock Text="{Binding ScheduleLifecycleReceiptSummary}" TextWrapping="Wrap" Foreground="#526071" />
                <TextBlock Text="{Binding ScheduleLifecycleReceiptStatus}" TextWrapping="Wrap" Foreground="#526071" />
                <TextBlock Text="{Binding ScheduleLifecycleReceiptLocation}" TextWrapping="Wrap" FontSize="11" Foreground="#687588" />
                <TextBlock Text="{Binding ScheduleLifecycleStatusSummary}" TextWrapping="Wrap" Foreground="#526071" />
                <TextBlock Text="{Binding ScheduleLifecycleStatusStatus}" TextWrapping="Wrap" Foreground="#526071" />
                <TextBlock Text="{Binding ScheduleLifecycleStatusMessage}" TextWrapping="Wrap" Foreground="#526071" />
                <TextBlock Text="{Binding ScheduleLifecycleStatusLocation}" TextWrapping="Wrap" FontSize="11" Foreground="#687588" />
              </StackPanel>
            </Border>
            <Grid ColumnDefinitions="*,*,*" ColumnSpacing="14">
              <StackPanel Spacing="6">
                <TextBlock Text="Queue State" FontWeight="SemiBold" Foreground="#172033" />
                <TextBlock Text="{Binding OperationsBoardQueueSummary}" TextWrapping="Wrap" Foreground="#526071" />
                <TextBlock Text="{Binding OperationsBoardLatestRequestStatus}" TextWrapping="Wrap" Foreground="#526071" />
              </StackPanel>
              <StackPanel Grid.Column="1" Spacing="6">
                <TextBlock Text="Command Link" FontWeight="SemiBold" Foreground="#172033" />
                <TextBlock Text="{Binding OperationsBoardLatestCommandStatus}" TextWrapping="Wrap" Foreground="#526071" />
                <TextBlock Text="{Binding OperationsBoardLatestExecutionStatus}" TextWrapping="Wrap" Foreground="#526071" />
              </StackPanel>
              <StackPanel Grid.Column="2" Spacing="6">
                <TextBlock Text="Safety And Ledgers" FontWeight="SemiBold" Foreground="#172033" />
                <TextBlock Text="{Binding OperationsBoardSafetySummary}" TextWrapping="Wrap" Foreground="#526071" />
                <TextBlock Text="{Binding OperationsBoardLedgerSummary}" TextWrapping="Wrap" FontSize="11" Foreground="#687588" />
                <TextBlock Text="{Binding CustomerStatusFeedbackLocation}" TextWrapping="Wrap" FontSize="11" Foreground="#687588" />
              </StackPanel>
            </Grid>
          </StackPanel>
        </Border>

        <Grid ColumnDefinitions="1.1*,1.4*" RowDefinitions="*,*" ColumnSpacing="18" RowSpacing="18">
          <Border Padding="20" CornerRadius="8" Background="White" BorderBrush="#dde3ed" BorderThickness="1">
            <StackPanel Spacing="12">
              <TextBlock Text="Calendar Board" FontSize="20" FontWeight="SemiBold" Foreground="#172033" />
              <TextBlock Text="Native-backed schedule and availability status for the internal operator shell." TextWrapping="Wrap" Foreground="#526071" />
              <TextBlock Text="{Binding CalendarSystem}" FontSize="26" FontWeight="SemiBold" Foreground="#294a80" />
              <TextBlock Text="Gregorian, revised 13-month, and side-by-side modes belong here in the App. MONITOR reports readiness only." TextWrapping="Wrap" Foreground="#526071" />
            </StackPanel>
          </Border>

          <Border Grid.Column="1" Padding="20" CornerRadius="8" Background="White" BorderBrush="#dde3ed" BorderThickness="1">
            <StackPanel Spacing="12">
              <TextBlock Text="Schedule Queue" FontSize="20" FontWeight="SemiBold" Foreground="#172033" />
              <TextBlock Text="{Binding ScheduleQueueStatus}" FontSize="26" FontWeight="SemiBold" Foreground="#7a4b12" />
              <TextBlock Text="Requests, holds, booking confirmations, receipts, and customer-safe timing returns are read through the Native C bridge." TextWrapping="Wrap" Foreground="#526071" />
              <TextBlock Text="{Binding ModuleSummary}" TextWrapping="Wrap" Foreground="#526071" />
              <TextBlock Text="Webportal Request Inbox" FontSize="16" FontWeight="SemiBold" Foreground="#172033" Margin="0,8,0,0" />
              <TextBlock Text="{Binding RequestInboxSummary}" TextWrapping="Wrap" Foreground="#526071" />
              <TextBlock Text="{Binding RequestInboxStatus}" TextWrapping="Wrap" Foreground="#526071" />
              <TextBlock Text="Request To Native Command" FontSize="16" FontWeight="SemiBold" Foreground="#172033" Margin="0,8,0,0" />
              <TextBlock Text="{Binding RequestCommandReceiptSummary}" TextWrapping="Wrap" Foreground="#526071" />
              <TextBlock Text="{Binding RequestCommandReceiptStatus}" TextWrapping="Wrap" Foreground="#526071" />
            </StackPanel>
          </Border>

          <Border Grid.Row="1" Padding="20" CornerRadius="8" Background="White" BorderBrush="#dde3ed" BorderThickness="1">
            <StackPanel Spacing="12">
              <TextBlock Text="Revised Calendar Lab" FontSize="20" FontWeight="SemiBold" Foreground="#172033" />
              <TextBlock Text="{Binding RevisedRulepackStatus}" FontSize="20" FontWeight="SemiBold" Foreground="#294a80" />
              <TextBlock Text="{Binding RevisedCalendarShape}" TextWrapping="Wrap" Foreground="#526071" />
              <TextBlock Text="{Binding RevisedCalendarBoundaryPolicies}" TextWrapping="Wrap" Foreground="#526071" />
              <TextBlock Text="{Binding RevisedCalendarAnchor}" TextWrapping="Wrap" Foreground="#526071" />
              <TextBlock Text="{Binding RevisedCalendarIntercalaryPolicy}" TextWrapping="Wrap" Foreground="#526071" />
              <TextBlock Text="{Binding RevisedCalendarGateReason}" TextWrapping="Wrap" Foreground="#526071" />
              <Border Padding="12" CornerRadius="8" Background="#f7fbff" BorderBrush="#d6e4f3" BorderThickness="1">
                <StackPanel Spacing="5">
                  <TextBlock Text="WORKSHOP Timing Export" FontWeight="SemiBold" Foreground="#172033" />
                  <TextBlock Text="{Binding RevisedTimingExportSummary}" TextWrapping="Wrap" Foreground="#526071" />
                  <TextBlock Text="{Binding RevisedTimingExportStatus}" TextWrapping="Wrap" Foreground="#526071" />
                  <TextBlock Text="{Binding RevisedTimingExportLocation}" TextWrapping="Wrap" FontSize="11" Foreground="#687588" />
                </StackPanel>
              </Border>
              <Border Padding="12" CornerRadius="8" Background="#f8f6ff" BorderBrush="#d6ceef" BorderThickness="1">
                <StackPanel Spacing="5">
                  <TextBlock Text="Recurring Revised Availability Exceptions" FontWeight="SemiBold" Foreground="#172033" />
                  <TextBlock Text="{Binding RevisedAvailabilityExceptionSummary}" TextWrapping="Wrap" Foreground="#526071" />
                  <TextBlock Text="{Binding RevisedAvailabilityExceptionStatus}" TextWrapping="Wrap" Foreground="#526071" />
                  <TextBlock Text="{Binding RevisedAvailabilityExceptionLocation}" TextWrapping="Wrap" FontSize="11" Foreground="#687588" />
                  <TextBlock Text="{Binding RevisedAvailabilityExceptionReceiptSummary}" TextWrapping="Wrap" Foreground="#526071" />
                  <TextBlock Text="{Binding RevisedAvailabilityExceptionReceiptStatus}" TextWrapping="Wrap" Foreground="#526071" />
                  <TextBlock Text="{Binding RevisedAvailabilityExceptionReceiptMessage}" TextWrapping="Wrap" Foreground="#526071" />
                  <TextBlock Text="{Binding RevisedAvailabilityExceptionReceiptLocation}" TextWrapping="Wrap" FontSize="11" Foreground="#687588" />
                </StackPanel>
              </Border>
              <Border Padding="12" CornerRadius="8" Background="#f7fff9" BorderBrush="#c9e7d1" BorderThickness="1">
                <StackPanel Spacing="5">
                  <TextBlock Text="Revised Reminder And Deadline Execution" FontWeight="SemiBold" Foreground="#172033" />
                  <TextBlock Text="{Binding RevisedReminderExecutionSummary}" TextWrapping="Wrap" Foreground="#526071" />
                  <TextBlock Text="{Binding RevisedReminderExecutionStatus}" TextWrapping="Wrap" Foreground="#526071" />
                  <TextBlock Text="{Binding RevisedDeadlineExecutionSummary}" TextWrapping="Wrap" Foreground="#526071" />
                  <TextBlock Text="{Binding RevisedDeadlineExecutionStatus}" TextWrapping="Wrap" Foreground="#526071" />
                  <TextBlock Text="{Binding RevisedDeadlineEscalationSummary}" TextWrapping="Wrap" Foreground="#526071" />
                  <TextBlock Text="{Binding RevisedDeadlineEscalationStatus}" TextWrapping="Wrap" Foreground="#526071" />
                  <TextBlock Text="{Binding RevisedReminderDeadlineReceiptSummary}" TextWrapping="Wrap" Foreground="#526071" />
                  <TextBlock Text="{Binding RevisedReminderDeadlineReceiptStatus}" TextWrapping="Wrap" Foreground="#526071" />
                  <TextBlock Text="{Binding RevisedReminderDeadlineReceiptLocation}" TextWrapping="Wrap" FontSize="11" Foreground="#687588" />
                </StackPanel>
              </Border>
            </StackPanel>
          </Border>

          <Border Grid.Row="1" Grid.Column="1" Padding="20" CornerRadius="8" Background="White" BorderBrush="#dde3ed" BorderThickness="1">
            <StackPanel Spacing="12">
              <TextBlock Text="Boundary Contract" FontSize="20" FontWeight="SemiBold" Foreground="#172033" />
              <TextBlock Text="{Binding BoundaryStatus}" FontSize="20" FontWeight="SemiBold" Foreground="#0f6844" />
              <TextBlock Text="EPOCH App owns scheduling and calendar product workflows. EPOCH MONITOR owns development/control status. WORKSHOP may request timing, but it does not own calendar state." TextWrapping="Wrap" Foreground="#526071" />
            </StackPanel>
          </Border>
        </Grid>
      </StackPanel>
    </ScrollViewer>

    <Border Grid.Row="2" Margin="0,18,0,0" Padding="18" CornerRadius="8" Background="#fffdf4" BorderBrush="#e4d48a" BorderThickness="1">
      <Grid ColumnDefinitions="*,*,*,1.2*" ColumnSpacing="18">
        <StackPanel Spacing="6">
          <TextBlock Text="Native Scheduling Command" FontSize="18" FontWeight="SemiBold" Foreground="#172033" />
          <TextBlock Text="{Binding CommandReadiness}" FontSize="16" FontWeight="SemiBold" Foreground="#7a4b12" />
        </StackPanel>
        <StackPanel Grid.Column="1" Spacing="6">
          <TextBlock Text="{Binding CommandSummary}" TextWrapping="Wrap" Foreground="#526071" />
          <TextBlock Text="{Binding CommandReceiptStatus}" TextWrapping="Wrap" Foreground="#526071" />
        </StackPanel>
        <StackPanel Grid.Column="2" Spacing="6">
          <TextBlock Text="Native Execution Receipt" FontSize="18" FontWeight="SemiBold" Foreground="#172033" />
          <TextBlock Text="{Binding ExecutionSafetyStatus}" FontSize="16" FontWeight="SemiBold" Foreground="#7a4b12" />
          <TextBlock Text="{Binding ExecutionReceiptSummary}" TextWrapping="Wrap" Foreground="#526071" />
          <TextBlock Text="{Binding ExecutionReceiptEvidence}" TextWrapping="Wrap" Foreground="#526071" />
        </StackPanel>
        <StackPanel Grid.Column="3" Spacing="6">
          <TextBlock Text="Execution History" FontSize="18" FontWeight="SemiBold" Foreground="#172033" />
          <TextBlock Text="{Binding ExecutionHistorySummary}" TextWrapping="Wrap" Foreground="#526071" />
          <TextBlock Text="{Binding LastExecutionHistoryStatus}" TextWrapping="Wrap" Foreground="#526071" />
          <TextBlock Text="{Binding ExecutionHistoryLocation}" TextWrapping="Wrap" FontSize="11" Foreground="#687588" />
          <TextBlock Text="{Binding CommandCustomerSafeStatus}" TextWrapping="Wrap" Foreground="#526071" />
          <TextBlock Text="{Binding ExecutionCustomerSafeStatus}" TextWrapping="Wrap" Foreground="#526071" />
        </StackPanel>
      </Grid>
    </Border>
  </Grid>
</Window>
